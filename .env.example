# Copy to .env and fill in your values, or run `bash install/docker-install.sh`
# which writes this file interactively.

# Paste the key from your ollebo.com mapserver entry.
# Reserved for future ollebo.com registration handshake — safe to leave empty
# today, but set it now so the install is ready.
OLLEBO_KEY=

# Tenant scope. First key in the terracotta [space, map, variant] schema.
OLLEBO_SPACE_ID=local

# Browser-facing tile URL. Must be reachable from any viewer (including
# ollebo.com). For local installs behind a tunnel, paste the ngrok/cloudflared
# https URL here.
TERRACOTTA_PUBLIC_URL=http://localhost:5001

# ollebo.com API base. Used by the dormant updateMap() registration call.
API=https://www.ollebo.com/api/v1

# Terracotta storage. Defaults match what's baked into the container.
TERRACOTTA_DB_PATH=/data/db/terracotta.sqlite
TERRACOTTA_PROVIDER=sqlite
